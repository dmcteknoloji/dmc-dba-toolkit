{
  "annotations": { "list": [] },
  "description": "DMC DBA Toolkit — MySQL InnoDB pressure. Source: dmc_monitor.innodb_pressure_snapshot (see mysql/monitoring/innodb-pressure-snapshot.sql).",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "DMC DBA Toolkit", "url": "https://github.com/dmcteknoloji/dmc-dba-toolkit", "type": "link", "icon": "external link", "targetBlank": true },
    { "title": "Sentinel DB 360", "url": "https://sentineldb360.com", "type": "link", "icon": "external link", "targetBlank": true }
  ],
  "panels": [
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 25 },
            { "color": "red", "value": 50 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT dirty_pages_pct FROM dmc_monitor.innodb_pressure_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Dirty pages %",
      "description": "Percentage of buffer pool data pages that are dirty. > 50% means IO can't keep up with writes.",
      "type": "stat"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 95 },
            { "color": "green", "value": 99 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT bp_hit_rate_pct FROM dmc_monitor.innodb_pressure_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Buffer pool hit rate %",
      "description": "Cumulative since startup. < 99% on busy OLTP usually means under-sized buffer pool.",
      "type": "stat"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT row_lock_waits_now FROM dmc_monitor.innodb_pressure_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Row-lock waiters (now)",
      "type": "stat"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT pending_reads_now + pending_writes_now AS pending_io FROM dmc_monitor.innodb_pressure_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Pending IO",
      "type": "stat"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "rawSql": "SELECT sample_utc AS time, dirty_pages_pct AS dirty_pct, bp_hit_rate_pct AS hit_rate FROM dmc_monitor.innodb_pressure_snapshot WHERE sample_utc > NOW() - INTERVAL 24 HOUR ORDER BY sample_utc", "refId": "A" }
      ],
      "title": "Buffer pool — last 24h",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "rawSql": "SELECT sample_utc AS time, row_lock_waits_now AS waiters_now, row_lock_waits_cum AS total_waits FROM dmc_monitor.innodb_pressure_snapshot WHERE sample_utc > NOW() - INTERVAL 24 HOUR ORDER BY sample_utc", "refId": "A" }
      ],
      "title": "Row lock waits — last 24h",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["dmc", "dba-toolkit", "mysql", "innodb"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DMC · MySQL InnoDB Pressure",
  "uid": "dmc-mysql-innodb",
  "version": 1
}
