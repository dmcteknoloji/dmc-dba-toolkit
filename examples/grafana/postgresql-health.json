{
  "annotations": { "list": [] },
  "description": "DMC DBA Toolkit — PostgreSQL health snapshot. Source: dmc_monitor.health_snapshot (see postgresql/monitoring/health-snapshot.sql).",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "DMC DBA Toolkit", "url": "https://github.com/dmcteknoloji/dmc-dba-toolkit", "type": "link", "icon": "external link", "targetBlank": true },
    { "title": "Sentinel DB 360", "url": "https://sentineldb360.com", "type": "link", "icon": "external link", "targetBlank": true }
  ],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT conn_active FROM dmc_monitor.health_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Active connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT conn_idle_in_xact FROM dmc_monitor.health_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Idle-in-transaction (now)",
      "description": "These backends hold locks and prevent vacuum cleanup. Anything > 0 deserves a look.",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 95 },
            { "color": "green", "value": 99 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT cache_hit_pct FROM dmc_monitor.health_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Cache hit %",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "red", "value": 1800 }
          ] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "rawSql": "SELECT oldest_xact_secs FROM dmc_monitor.health_snapshot ORDER BY sample_utc DESC LIMIT 1", "refId": "A" }
      ],
      "title": "Oldest running xact",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "rawSql": "SELECT sample_utc AS time, conn_total AS total, conn_active AS active, conn_idle_in_xact AS idle_in_xact FROM dmc_monitor.health_snapshot WHERE sample_utc > now() - interval '24 hours' ORDER BY sample_utc", "refId": "A" }
      ],
      "title": "Connections breakdown — last 24h",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": { "defaults": { "unit": "decbytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "rawSql": "SELECT sample_utc AS time, replay_lag_bytes FROM dmc_monitor.health_snapshot WHERE sample_utc > now() - interval '24 hours' AND replay_lag_bytes IS NOT NULL ORDER BY sample_utc", "refId": "A" }
      ],
      "title": "Replay lag (bytes) — only on standby",
      "description": "NULL on primary; meaningful only when sampled from a standby member.",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["dmc", "dba-toolkit", "postgresql", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DMC · PostgreSQL Health",
  "uid": "dmc-pg-health",
  "version": 1
}
