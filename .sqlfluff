[sqlfluff]
dialect = tsql
templater = raw
max_line_length = 200
# This toolkit is hand-formatted for readability: box-art headers, vertical
# alignment of columns and AS-keywords, multi-line CASE expressions. Most
# sqlfluff layout rules conflict with that style. We keep the parsing/syntax
# rules on (so a typo still trips CI) and disable the cosmetic ones.
exclude_rules =
    aliasing.expression,
    aliasing.length,
    ambiguous.column_count,
    capitalisation.functions,
    capitalisation.identifiers,
    capitalisation.keywords,
    capitalisation.literals,
    capitalisation.types,
    convention.casting_style,
    convention.coalesce,
    convention.count_rows,
    convention.is_null,
    convention.left_join,
    convention.not_equal,
    convention.select_trailing_comma,
    convention.statement_brackets,
    convention.terminator,
    layout.cte_bracket,
    layout.cte_newline,
    layout.functions,
    layout.indent,
    layout.keyword_newline,
    layout.long_lines,
    layout.newlines,
    layout.operators,
    layout.select_modifiers,
    layout.select_targets,
    layout.spacing,
    layout.start_of_file,
    references.consistent,
    references.keywords,
    references.qualification,
    references.quoting,
    references.special_chars,
    structure.column_order,
    structure.distinct,
    structure.else_null,
    structure.join_condition_order,
    structure.nested_case,
    structure.simple_case,
    structure.subquery,
    structure.unused_cte,
    structure.using
